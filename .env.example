# ─── API ──────────────────────────────────────────────────────────────────────
# API origin only — no trailing slash, no /api suffix (endpoints include /api).
#
# Production (Liara / static SPA): browser calls API directly — no CORS issues on store.a4j.ir
NUXT_PUBLIC_API_BASE_URL=https://api.store.a4j.ir

# Nitro dev-server proxy target (origin only, no /api suffix). Forwarded as .../api/... in dev.
NUXT_PUBLIC_API_PROXY_TARGET=https://api.store.a4j.ir

# Axios request timeout in milliseconds (default: 30000)
NUXT_PUBLIC_API_TIMEOUT=30000

# ─── App ──────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_TITLE=My App
NUXT_PUBLIC_APP_NAME=My App
NUXT_PUBLIC_APP_DESCRIPTION=An admin dashboard
# Semantic version — edit only app.version.json (PWA /version.json on deploy)

# ─── Branding ─────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_THEME_COLOR=#00B894
NUXT_PUBLIC_APP_BG_COLOR=#f4f5f6
NUXT_PUBLIC_APP_STORAGE_PREFIX=app

# ─── Guest tickets ───────────────────────────────────────────────────────────
NUXT_PUBLIC_GUEST_TICKET_TYPE_ID=
NUXT_PUBLIC_GUEST_DEPARTMENT_ID=

# ─── Soft Store (public storefront) ───────────────────────────────────────────
# Canonical site URL for SEO canonical/hreflang and robots.txt
NUXT_PUBLIC_SITE_URL=https://store.a4j.ir

# Feature flags — set true when backend catalog/commerce/licensing/finance APIs are live
# Production storefront: set when backend APIs are deployed
NUXT_PUBLIC_CATALOG_API_LIVE=false
NUXT_PUBLIC_COMMERCE_API_LIVE=false
NUXT_PUBLIC_LICENSING_API_LIVE=false
NUXT_PUBLIC_FINANCE_API_LIVE=false

# On-demand ISR revalidation (Nuxt server route POST /_revalidate)
# Backend: NUXT_REVALIDATE_URL=https://store.a4j.ir/_revalidate
NUXT_REVALIDATE_SECRET=change-me-in-production
