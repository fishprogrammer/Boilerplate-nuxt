# ─── API ──────────────────────────────────────────────────────────────────────
# Same-origin proxy (dev + node-server): /api
# Liara static production: full API origin (CORS allowed for boilerplate-store.liara.run)
NUXT_PUBLIC_API_BASE_URL=/api
NUXT_PUBLIC_API_PROXY_TARGET=https://api.store.a4j.ir

# Axios request timeout in milliseconds (default: 30000)
NUXT_PUBLIC_API_TIMEOUT=30000

# ─── App ──────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_TITLE=Soft Store
NUXT_PUBLIC_APP_NAME=Soft Store
NUXT_PUBLIC_APP_DESCRIPTION=فروشگاه نرم‌افزار و افزونه‌های وردپرس
# Semantic version — edit only app.version.json (PWA /version.json on deploy)

# ─── Branding ─────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_THEME_COLOR=#00B894
NUXT_PUBLIC_APP_BG_COLOR=#f4f5f6
NUXT_PUBLIC_APP_STORAGE_PREFIX=app

# ─── Guest tickets ───────────────────────────────────────────────────────────
NUXT_PUBLIC_GUEST_TICKET_TYPE_ID=
NUXT_PUBLIC_GUEST_DEPARTMENT_ID=

# ─── Soft Store (public storefront) ───────────────────────────────────────────
# Canonical site URL for SEO canonical/hreflang and robots.txt
NUXT_PUBLIC_SITE_URL=https://boilerplate-store.liara.run

# Feature flags — set true when backend APIs are deployed (required for production)
NUXT_PUBLIC_CATALOG_API_LIVE=true
NUXT_PUBLIC_COMMERCE_API_LIVE=true
NUXT_PUBLIC_LICENSING_API_LIVE=true
NUXT_PUBLIC_FINANCE_API_LIVE=true

# GA4 — fallback when GET /api/seo/public-settings/ has no measurement ID
NUXT_PUBLIC_GA4_ID=

# On-demand ISR revalidation (Nuxt server route POST /_revalidate)
# Backend: nuxt_revalidate_url in PATCH /api/seo/settings/
NUXT_REVALIDATE_SECRET=change-me-in-production
